---
import { existsSync } from 'node:fs'
import path from 'node:path'
import { CONTACT_CONFIG, HERO_METRIC_CONFIG, HOME_LABELS, POSTS_CONFIG, PRICE_TYPE_LABELS, SOCIAL_ICON_MAP } from '~/config.ts'
import FloatingContactCard from '~/components/base/FloatingContactCard.astro'
import FaqSection from '~/components/base/FaqSection.astro'
import HeroMetric from '~/components/base/HeroMetric.astro'
import ProductsSlider from '~/components/base/ProductsSlider.astro'
import ReviewsSection from '~/components/base/ReviewsSection.astro'
import ServicesList from '~/components/base/ServicesList.astro'
import HomeLayout from '~/layouts/HomeLayout.astro'
import SectionDivider from '~/components/base/SectionDivider.astro'
import SocialLink from '~/components/base/SocialLink.astro'
import List from '~/components/posts/card/List.astro'
import { getNumPosts, getPinnedPosts } from '~/lib/data'
import { getSiteData } from '~/lib/site-data'
import { formatBrazilianPhoneDisplay, truncateText } from '~/lib/utils'

const { size, type } = POSTS_CONFIG.homePageConfig
const siteData = await getSiteData()
const sections = siteData.body.sections ?? []
const siteBrand = siteData.body.brand || siteData.head.title
const siteCategory = siteData.body.category || ''
const siteTagline = siteData.body.tagline || ''
const siteRating = siteData.body.rating
const siteReviewCount = siteData.body.reviewCount
const sitePhone = siteData.body.phone || ''
const sitePhoneDisplay = formatBrazilianPhoneDisplay(sitePhone)
const siteAddress = siteData.body.address || ''
const siteOpenStatus = siteData.body.openStatus
const siteCity = siteData.body.city || ''
const phoneDigits = sitePhone.replace(/\D/g, '')
const phoneHref = CONTACT_CONFIG.wap ? `https://wa.me/${phoneDigits}` : `tel:${phoneDigits}`
const phoneLabel = CONTACT_CONFIG.wap ? HOME_LABELS.contactInfoWhatsApp : HOME_LABELS.contactInfoPhone
const uberClientId = import.meta.env.PUBLIC_UBER_CLIENT_ID
const generatedLocationMapLightURL = '/generated/location-map-light.avif'
const generatedLocationMapDarkURL = '/generated/location-map-dark.avif'
const generatedLocationMapLightMobileURL = '/generated/location-map-light-mobile.avif'
const generatedLocationMapDarkMobileURL = '/generated/location-map-dark-mobile.avif'
const generatedLocationMapLightPath = path.resolve(process.cwd(), 'public/generated/location-map-light.avif')
const generatedLocationMapDarkPath = path.resolve(process.cwd(), 'public/generated/location-map-dark.avif')
const generatedLocationMapLightMobilePath = path.resolve(process.cwd(), 'public/generated/location-map-light-mobile.avif')
const generatedLocationMapDarkMobilePath = path.resolve(process.cwd(), 'public/generated/location-map-dark-mobile.avif')
const shouldUseGeneratedLocationMaps =
  existsSync(generatedLocationMapLightPath) &&
  existsSync(generatedLocationMapDarkPath) &&
  existsSync(generatedLocationMapLightMobilePath) &&
  existsSync(generatedLocationMapDarkMobilePath)
const locationDescription = HOME_LABELS.locationDescriptionTemplate.replace('{city}', siteCity)
const shouldShowHeroMetric = siteRating !== undefined || siteReviewCount !== undefined

const formatServiceType = (priceType?: string) => {
  if (priceType === 'fixed') return HOME_LABELS.fixedPriceLabel
  if (priceType === 'free') return HOME_LABELS.freePriceLabel
  if (priceType === 'none') return HOME_LABELS.noPriceLabel
  return HOME_LABELS.startingAtLabel
}

let showPosts = []
const pinnedPosts = await getPinnedPosts()
const hasPinnedPosts = pinnedPosts.length > 0
if (hasPinnedPosts) {
  showPosts = pinnedPosts
} else {
  showPosts = await getNumPosts(size)
}
---

<HomeLayout
  title={siteData.head.title}
  description={siteData.head.description}
  schemaGraph={siteData.schemaGraph}
  useTitleAsIs
>
  <div class="relative z-[1]">
    <div class="home-hero">
      <h1>
        <span class="text-balance">{siteCategory}</span>
        <span>{siteBrand}</span>
      </h1>
      <div class="home-hero-copy text-pretty">
        <p>{truncateText(siteTagline, 150)}</p>
      </div>
      <div class="home-nap">
            <div class="home-nap-item home-nap-item--business pr-1">
          <span class="home-nap-icon icon-[mdi--office-building] text-primary"></span>
          <div>
            <p class="text-sm font-medium text-muted-foreground">{siteBrand}</p>
            {siteOpenStatus && <p class="text-sm text-[#007a4d] dark:text-[#18d38a]">{siteOpenStatus}</p>}
          </div>
        </div>
        {
          siteAddress && (
            <>
              <div
                aria-hidden="true"
                class="home-nap-divider hidden md:block self-stretch w-px shrink-0"
              ></div>
              <div class="home-nap-item home-nap-item--address">
                <span class="home-nap-icon icon-[mdi--map-marker] text-primary"></span>
                <p class="text-sm text-muted-foreground">{siteAddress}</p>
              </div>
            </>
          )
        }
        {
          phoneDigits && (
            <>
              <div
                aria-hidden="true"
                class="home-nap-divider hidden md:block self-stretch w-px shrink-0"
              ></div>
              <div class="home-nap-item home-nap-item--contact">
                <a
                  href={phoneHref}
                  target={CONTACT_CONFIG.wap ? '_blank' : undefined}
                  rel={CONTACT_CONFIG.wap ? 'noreferrer' : undefined}
                  class="inline-flex items-start gap-3 text-left transition hover:text-primary"
                >
                  <span class:list={[CONTACT_CONFIG.wap ? 'icon-[ri--whatsapp-fill]' : 'icon-[mdi--phone]', 'mt-0.5 size-6 shrink-0 text-foreground']}></span>
                  <div>
                    <p class="text-sm text-muted-foreground">{phoneLabel}</p>
                    <p class="font-mono text-sm font-medium text-muted-foreground">{sitePhoneDisplay || sitePhone}</p>
                  </div>
                </a>
              </div>
            </>
          )
        }
      </div>
      <div class="home-social-row">
        {
          shouldShowHeroMetric && (
            <HeroMetric
              icon={HERO_METRIC_CONFIG.icon}
              primaryValue={siteRating ?? ''}
              primaryLabel={HERO_METRIC_CONFIG.primaryLabel}
              secondaryValue={siteReviewCount}
              secondaryLabel={HERO_METRIC_CONFIG.secondaryLabel}
            />
          )
        }
        {
          siteData.socialLinks.map((item) => {
            const icon = item.icon || SOCIAL_ICON_MAP[item.name] || ''
            if (!icon) return null
            return <SocialLink href={item.url} icon={icon} aria-label={`${HOME_LABELS.socialLinkAriaLabelPrefix} ${item.name}`} count={item.count} label={item.label} />
          })
        }
      </div>
    </div>
    {
      sections.map((section, sectionIndex) => (
        <>
          <SectionDivider />
          <div class="home-section-shell">
            {
              section.key === 'reviews' && section.items ? (
                <ReviewsSection
                  title={section.title}
                  description={section.description}
                  reviews={section.items}
                  metric={{
                    icon: HERO_METRIC_CONFIG.icon,
                    primaryValue: siteRating ?? '',
                    primaryLabel: HERO_METRIC_CONFIG.primaryLabel,
                    secondaryValue: siteReviewCount,
                    secondaryLabel: HERO_METRIC_CONFIG.secondaryLabel,
                  }}
                />
              ) : section.key === 'products' && section.products ? (
                <>
                  <ProductsSlider
                    title={section.title}
                    description={section.description}
                    products={section.products.map((product, productIndex) => ({
                      thumbSrc: existsSync(path.resolve(process.cwd(), `public/generated/product-thumbs/${sectionIndex}-${productIndex}.avif`))
                        ? `/generated/product-thumbs/${sectionIndex}-${productIndex}.avif`
                        : undefined,
                      imageSrc: product.imageUrl,
                      name: product.title,
                      category: product.category,
                      price: product.price,
                      url: product.url,
                      type: PRICE_TYPE_LABELS[product.priceType] ?? '',
                      period: product.period || '',
                    }))}
                  />
                </>
              ) : section.key === 'services' && section.services ? (
                <>
                  <h2 class="text-2xl sm:text-3xl tracking-tight">{section.title}</h2>
                  <p class="text-muted-foreground mb-6 mt-2">{section.description}</p>
                  <ServicesList
                    services={section.services.map((service) => ({
                      name: service.title,
                      type:
                        service.priceType === 'starting_at'
                          ? '__starting_at_icon__'
                          : service.priceType === 'fixed'
                            ? '__fixed_icon__'
                            : formatServiceType(service.priceType),
                      currency: service.currency || undefined,
                      price:
                        service.priceType === 'fixed' || service.priceType === 'starting_at'
                          ? service.price || undefined
                          : undefined,
                      period: service.period || undefined,
                    }))}
                  />
                </>
              ) : section.key === 'faqs' && section.faqs && section.faqs.length > 0 ? (
                <>
                  <FaqSection title={section.title} description={section.description} faqs={section.faqs} />
                </>
              ) : (
                <>
                  <div class:list={['mb-6', section.key === 'location' && 'grid gap-6 md:grid-cols-[1fr_auto] md:items-start']}>
                    <div>
                      <h2>{section.title}</h2>
                      <p class="home-section-copy">
                        {section.key === 'location' ? locationDescription : section.description}
                      </p>
                    </div>
                    {
                      section.key === 'location' && uberClientId && section.latitude !== undefined && section.longitude !== undefined && (
                        <a
                          href={`https://m.uber.com/ul/?client_id=${encodeURIComponent(uberClientId)}&action=setPickup&pickup=my_location&dropoff[latitude]=${section.latitude}&dropoff[longitude]=${section.longitude}`}
                          target="_blank"
                          rel="noreferrer"
                          class="flex min-w-[220px] items-start gap-4 rounded-2xl border border-border/60 bg-card/40 px-4 py-3 transition hover:bg-accent/40"
                        >
                          <span class="icon-[mdi--car] mt-0.5 size-6 shrink-0 text-foreground"></span>
                          <div>
                            <p class="text-[0.92rem] font-medium text-foreground">{HOME_LABELS.uberCtaTitle}</p>
                            <p class="text-muted-foreground text-sm">{HOME_LABELS.uberCtaDescription}</p>
                          </div>
                        </a>
                      )
                    }
                  </div>
                  {
                    section.key === 'location' && shouldUseGeneratedLocationMaps ? (
                      <>
                        <a
                          href={section.googleMapsUri || '#'}
                          target="_blank"
                          rel="noreferrer"
                          title={HOME_LABELS.openMapTitle}
                          class="block overflow-hidden border border-border/50"
                        >
                          <picture data-location-map>
                            <source
                              media="(max-width: 767px)"
                              data-light-srcset={generatedLocationMapLightMobileURL}
                              data-dark-srcset={generatedLocationMapDarkMobileURL}
                              width="378"
                              height="378"
                            />
                            <img
                              data-light-src={generatedLocationMapLightURL}
                              data-dark-src={generatedLocationMapDarkURL}
                              alt={`${section.title} map`}
                              width="700"
                              height="350"
                              loading="eager"
                              fetchpriority="high"
                              class="home-location-map w-full object-cover"
                            />
                          </picture>
                        </a>
                        <script is:inline>
                          (() => {
                            const syncLocationMaps = () => {
                              const isDark = document.documentElement.classList.contains('dark')
                              document.querySelectorAll('[data-location-map]').forEach((picture) => {
                                if (!(picture instanceof HTMLPictureElement)) return
                                const source = picture.querySelector('source')
                                const image = picture.querySelector('img')
                                if (!(source instanceof HTMLSourceElement) || !(image instanceof HTMLImageElement)) return

                                const nextSourceSet = isDark ? source.dataset.darkSrcset : source.dataset.lightSrcset
                                const nextSrc = isDark ? image.dataset.darkSrc : image.dataset.lightSrc

                                if (nextSourceSet) {
                                  source.srcset = nextSourceSet
                                }
                                if (nextSrc) {
                                  const srcChanged = image.getAttribute('src') !== nextSrc
                                  if (srcChanged) {
                                    image.src = nextSrc
                                  }
                                }
                              })
                            }

                            document.addEventListener('theme:change', syncLocationMaps)
                            document.addEventListener('astro:page-load', syncLocationMaps)
                            syncLocationMaps()
                          })()
                        </script>
                      </>
                    ) : section.key === 'location' && section.googleMapsUri && (
                      <a
                        href={section.googleMapsUri}
                        target="_blank"
                        rel="noreferrer"
                        title={HOME_LABELS.openMapTitle}
                        class="block overflow-hidden border border-border/50"
                      >
                        <div class="flex min-h-[18rem] items-center justify-center bg-accent/20 text-center text-muted-foreground">
                          <div>
                            <span class="icon-[mdi--map-outline] mx-auto mb-3 block size-10"></span>
                            <p>{HOME_LABELS.openMapTitle}</p>
                          </div>
                        </div>
                      </a>
                    )
                  }
                </>
              )
            }
          </div>
        </>
      ))
    }
    <SectionDivider />
    <div class="home-section-shell">
      <h2>{HOME_LABELS.postsTitle}</h2>
      <p class="home-section-copy mb-6">
        {hasPinnedPosts ? HOME_LABELS.pinnedLabel : HOME_LABELS.recentLabel}
        {showPosts.length} {HOME_LABELS.postsSummarySuffix}
      </p>
      <List posts={showPosts} {type} coverLayout={POSTS_CONFIG.homePageConfig?.coverLayout} useHomeThumbs animate={false} />
    </div>
  </div>
  <FloatingContactCard phone={sitePhone} wap={CONTACT_CONFIG.wap} />
</HomeLayout>
