---
import { HOME_LABELS } from '~/config.ts'

type Position = 'bottom-right' | 'bottom-left' | 'top-right' | 'top-left'

type Props = {
  phone?: string
  wap: boolean
  position?: Position
}

const { phone, wap, position = 'bottom-right' }: Props = Astro.props

const phoneDigits = phone?.replace(/\D/g, '') ?? ''
const href = wap ? `https://wa.me/${phoneDigits}` : `tel:${phoneDigits}`

const positionClasses: Record<Position, string> = {
  'bottom-right': 'bottom-6 right-6',
  'bottom-left': 'bottom-6 left-6',
  'top-right': 'top-6 right-6',
  'top-left': 'top-6 left-6',
}
---

{
  phoneDigits && (
    <a
      href={href}
      target={wap ? '_blank' : undefined}
      rel={wap ? 'noreferrer' : undefined}
      class:list={[
        'fixed z-[120] inline-flex items-center justify-center gap-4 rounded-2xl border border-border/60 bg-card/90 px-6 py-3 text-center shadow-sm backdrop-blur transition hover:bg-accent/40',
        positionClasses[position],
      ]}
    >
      <span class:list={[wap ? 'icon-[ri--whatsapp-fill]' : 'icon-[mdi--phone]', 'size-6 shrink-0 text-foreground']}></span>
      <p class="text-sm font-medium text-muted-foreground">{HOME_LABELS.contactUs}</p>
    </a>
  )
}
