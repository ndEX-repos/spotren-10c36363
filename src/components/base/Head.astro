---
import path from 'node:path'
import { readFileSync } from 'node:fs'
import { SITE_CONFIG } from '~/config'
import { getSiteData } from '~/lib/site-data'

type Props = {
  title: string
  description: string
  image?: string
}

const { title, description, image }: Props = Astro.props
const siteData = await getSiteData()
const googleAnalyticsId = import.meta.env.PUBLIC_GOOGLE_ANALYTICS_ID
const themeScript = readFileSync(path.resolve(process.cwd(), 'public/js/theme.js'), 'utf8')

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const resolvedOgImage = image || siteData.head.ogImage?.url
const ogImage = resolvedOgImage ? new URL(resolvedOgImage, Astro.url) : null
---

<meta charset="UTF-8" />
<script is:inline set:html={themeScript}></script>

<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="google" content="notranslate" />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content={SITE_CONFIG.author} />

<meta name="theme-color" content="" />
<meta name="color-scheme" content="light dark" />

{siteData.head.icon?.url && <link rel="icon" href={siteData.head.icon.url} sizes="180x180" />}
{siteData.head.icon?.url && <link rel="apple-touch-icon" href={siteData.head.icon.url} />}

{/* RSS Feed Link */}
<link rel="alternate" type="application/rss+xml" title={siteData.head.title} href={new URL('/rss.xml', Astro.site).href} />

<link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />

<link rel="preload" href="/fonts/geist-v5-latin-regular.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
<link rel="preload" href="/fonts/geist-v5-latin-500.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
<link rel="preload" href="/fonts/lexend-v26-latin-500.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
<link rel="preload" href="/fonts/geist-mono-v5-latin-regular.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

<link rel="canonical" href={canonicalURL} />

<link rel="sitemap" href="/sitemap-index.xml" />

<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:site_name" content={siteData.head.title} />
<meta property="og:description" content={description} />
{ogImage && <meta property="og:image" content={ogImage} />}

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
{ogImage && <meta property="twitter:image" content={ogImage} />}
{
  googleAnalyticsId && (
    <>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}></script>
      <script is:inline define:vars={{ id: googleAnalyticsId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', id);
      </script>
    </>
  )
}
