---
type ServiceItem = {
  name: string
  type: string
  price?: string
  currency?: string
  period?: string
  content?: string
  ctaText?: string
  url?: string
}

type Props = {
  services: ServiceItem[]
}

const { services }: Props = Astro.props
---

<div>
  {
    services.map((service) => (
      (() => {
        const currency = service.currency || (service.price ? 'R$' : '')
        const hasContent = Boolean(service.content?.trim())
        const hasAside = Boolean(service.url?.trim() && service.ctaText?.trim())
        const serviceMeta =
          service.type === '__starting_at_icon__' ? (
            <span class="inline-flex items-end gap-3 leading-none">
              <span class="icon-[mdi--rocket-launch] text-xl text-muted-foreground/80 leading-none"></span>
              {service.price ? <span class="text-muted-foreground/90">{currency ? `${currency} ` : ''}{service.price}{service.period ? ` ${service.period}` : ''}</span> : ''}
            </span>
          ) : service.type === '__fixed_icon__' ? (
            <span class="inline-flex items-end gap-3 leading-none">
              <span class="icon-[mdi--cash-multiple] text-xl text-muted-foreground/80 leading-none"></span>
              {service.price ? <span class="text-muted-foreground/90">{currency ? `${currency} ` : ''}{service.price}{service.period ? ` ${service.period}` : ''}</span> : ''}
            </span>
          ) : (
            <span class="text-muted-foreground/90">
              {service.type}
              {service.price ? ` ${currency ? `${currency} ` : ''}${service.price}${service.period ? ` ${service.period}` : ''}` : ''}
            </span>
          )
        return (
      hasContent ? (
        <details class="group border-b border-border/30 last:border-b-0" open={false}>
          <summary class="flex cursor-pointer items-center justify-between gap-4 py-3 list-none transition-colors duration-200 group-hover:text-primary">
            <div class="flex flex-1 items-center gap-3 pr-4">
              <span class="relative size-4 shrink-0 text-muted-foreground transition-transform duration-200 group-open:rotate-45">
                <span class="absolute left-1/2 top-1/2 h-0.5 w-4 -translate-x-1/2 -translate-y-1/2 rounded-full bg-current"></span>
                <span class="absolute left-1/2 top-1/2 h-4 w-0.5 -translate-x-1/2 -translate-y-1/2 rounded-full bg-current transition-opacity duration-200 group-open:opacity-0"></span>
              </span>
              <span class="text-base font-medium text-muted-foreground/90 transition-colors duration-200 group-hover:text-primary line-clamp-1">
                {service.name}
              </span>
            </div>
            <span class="flex-shrink-0 text-base transition-colors duration-200 group-hover:text-primary whitespace-nowrap font-mono">
              {serviceMeta}
            </span>
          </summary>
          <div class:list={[
            'pb-4 pl-7',
            hasAside && 'md:grid md:grid-cols-[minmax(0,2fr)_minmax(0,1fr)] md:gap-6',
          ]}>
            <div
              class="text-sm leading-6 text-muted-foreground [&_p+p]:mt-4 [&_strong]:font-medium [&_strong]:text-foreground"
              set:html={service.content}
            />
            {
              hasAside && (
                <div class="mt-4 w-full md:mt-0 md:ml-auto md:max-w-[380px]">
                  {
                    service.url?.trim() && service.ctaText?.trim() ? (
                      <a
                        href={service.url}
                        target="_blank"
                        rel="noreferrer"
                        class="inline-flex w-full items-center justify-center gap-3 rounded-2xl border border-border/60 bg-card/40 px-4 py-3 text-center text-sm font-medium text-foreground transition hover:bg-accent/40"
                      >
                        <span>{service.ctaText}</span>
                        <span class="icon-[mdi--arrow-top-right] size-4 shrink-0"></span>
                      </a>
                    ) : null
                  }
                </div>
              )
            }
          </div>
        </details>
      ) : (
        <div class="group flex items-center justify-between gap-4 border-b border-border/30 py-3 last:border-b-0">
          <div class="flex-1 pr-4">
            <div class="text-base font-medium text-muted-foreground/90 transition-colors duration-200 group-hover:text-primary line-clamp-1">
              {service.name}
            </div>
          </div>
          <div class="flex-shrink-0 text-base transition-colors duration-200 group-hover:text-primary whitespace-nowrap font-mono">
            {serviceMeta}
          </div>
        </div>
      )
        )
      })()
    ))
  }
</div>
