---
import { existsSync } from 'node:fs'
import path from 'node:path'
import LqipImage from '~/components/base/LqipImage.astro'
import { formatDate } from '~/lib/utils'
import { POSTS_CONFIG } from '~/config'
import Badge from '~/components/posts/base/Badge.astro'
import type { CardProps } from './List.astro'

interface Props extends CardProps {}

const { post, index, coverLayout, useHomeThumbs = false, class: className, style }: Props = Astro.props

// 固定图片尺寸为 1200*630，宽高比约为 1.9:1
const IMAGE_WIDTH = 1200
const IMAGE_HEIGHT = 630

const imagePosition = post.data.coverLayout || coverLayout || (index % 2 === 1 ? 'right' : 'left')
const isReverse = imagePosition === 'right'
const recommendText = POSTS_CONFIG.recommendText
const postHref = `/posts/${post.id}`
const coverLinkAriaLabel = `Open post: ${post.data.title}`
const homeThumbPath = path.resolve(process.cwd(), `public/generated/post-thumbs/${post.id}.avif`)
const homeThumbSrc = useHomeThumbs && existsSync(homeThumbPath) ? `/generated/post-thumbs/${post.id}.avif` : null
---

<article class:list={[`group flex flex-col sm:flex-row gap-6 sm:gap-10 ${isReverse ? 'sm:flex-row-reverse' : ''}`, className]} {style}>
  <div class="sm:w-[min(38%,380px)] sm:max-w-[380px] sm:shrink-0 flex flex-col overflow-hidden">
    <a href={postHref} aria-label={coverLinkAriaLabel} title={coverLinkAriaLabel} class="block relative">
      <div class="aspect-[1200/630] overflow-hidden bg-muted/30 relative">
        {
          homeThumbSrc ? (
            <img
              src={homeThumbSrc}
              alt={post.data.title}
              width="380"
              height="200"
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover"
            />
          ) : post.data.cover && (
            <LqipImage
              src={post.data.cover}
              alt=""
              width={IMAGE_WIDTH}
              height={IMAGE_HEIGHT}
              loading="lazy"
              decoding="async"
              format="webp"
              class="w-full h-full object-cover"
            />
          )
        }
      </div>
    </a>
  </div>

  <div class="w-full min-w-0 flex flex-col justify-start">
    <div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground/90 mb-2">
      <time class="flex items-center gap-2">
        <span class="icon-[ph--calendar-blank] size-4"></span>
        {formatDate(post.data.pubDate)}
      </time>

      {
        post.data.updatedDate && (
          <time class="flex items-center gap-2">
            <span class="icon-[ph--clock-clockwise] size-4" />
            {formatDate(post.data.updatedDate)}
          </time>
        )
      }
    </div>

    <a href={postHref} class="group/title">
      <h3 class="text-base font-medium transition-colors group-hover/title:text-primary line-clamp-2 leading-5 mb-1">
        {post.data.title}
      </h3>
      {post.data.description && <p class="text-sm text-muted-foreground line-clamp-2 leading-5 mb-3">{post.data.description}</p>}
    </a>

    <div class="flex flex-wrap items-center gap-2 mb-3">
      {post.data.recommend && <Badge type="recommend" content={recommendText} />}
      {post.data.tags?.map((tag) => <Badge type="tag" content={tag} />)}
    </div>
  </div>
</article>
